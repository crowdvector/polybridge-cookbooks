# Optional: used only by workflows that explicitly run live PolyBridge mode.
# Offline mode does not use this value. If unset, live PolyBridge mode omits Authorization.
# POLYBRIDGE_API_KEY=

# Optional: used only by workflows that explicitly run Alpaca paper account validation.
# Preview-only mode does not use these values. Use paper keys only.
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=
# APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Optional cookbook aliases for the same explicit paper validation workflow.
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_PAPER_TRADE=true
