# Optional: set POLYBRIDGE_API_KEY only if a future live workflow explicitly asks for it.
# Offline PR 1 cookbooks do not use this value.
# POLYBRIDGE_API_KEY=your_api_key_here

# Optional future Alpaca paper-mode placeholders.
# Offline PR 1 does not read these values, does not call Alpaca, and does not submit orders.
# ALPACA_API_KEY=your_paper_api_key_here
# ALPACA_SECRET_KEY=your_paper_secret_key_here
# ALPACA_PAPER_TRADE=true
