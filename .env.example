# Optional: used only by workflows that explicitly run live PolyBridge mode.
# Offline mode does not use this value. If unset, live PolyBridge mode omits Authorization.
# POLYBRIDGE_API_KEY=your_api_key_here

# Optional future Alpaca paper-mode placeholders.
# Agentic Finance does not read these values, does not call Alpaca, and does not submit orders.
# ALPACA_API_KEY=your_paper_api_key_here
# ALPACA_SECRET_KEY=your_paper_secret_key_here
# ALPACA_PAPER_TRADE=true
